---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import "../styles/global.css";
import { getCollection } from 'astro:content';

const allSponsors = await getCollection('sponsors');

const tiers = [
	{ key: 'platinum', label: 'Platinum Sponsors' },
	{ key: 'gold', label: 'Gold Sponsors' },
	{ key: 'silver', label: 'Silver Sponsors' },
	{ key: 'digital', label: 'Digital Sponsors' },
	{ key: 'closed-caption', label: 'Closed Captioning Sponsor' },
	{ key: 'lanyard', label: 'Lanyard Sponsor' },
	{ key: 'breakfast', label: 'Breakfast Sponsors' },
	{ key: 'lunch', label: 'Lunch Sponsors' },
	{ key: 'break', label: 'Break Sponsors' },
	{ key: 'social', label: 'Social Sponsors' },
	{ key: 'community', label: 'Community Sponsors' },
] as const;

const tierBenefits = [
	{ label: 'Investment', platinum: '$7,000', gold: '$4,000', silver: '$2,000', digital: '$500', isPrice: true },
	{ label: 'Logo on website', platinum: true, gold: true, silver: true, digital: true },
	{ label: 'Logo on rotation slide during event', platinum: true, gold: true, silver: true, digital: true },
	{ label: 'Social media mentions', platinum: true, gold: true, silver: true, digital: true },
	{ label: '10% discount code', platinum: true, gold: true, silver: true, digital: true },
	{ label: 'Opportunity for on-stage raffle drawing', platinum: true, gold: true, silver: true, digital: false },
	{ label: 'Lead scanning', platinum: true, gold: true, silver: true, digital: false },
	{ label: 'Display table (6 ft)', platinum: 'Dedicated', gold: 'Shared (1/2)', silver: 'Shared (1/3)', digital: false },
	{ label: 'Main stage pitch', platinum: '1 minute', gold: '30 seconds', silver: 'MC delivered', digital: false },
	{ label: 'Included passes', platinum: '4', gold: '2', silver: '1', digital: false },
	{ label: 'Opportunity to sponsor hands-on workshop', platinum: true, gold: false, silver: false, digital: false },
];
---

<Layout>
	<Nav currentPage="/sponsors" />

	<div class="flex-1">

		<!-- Prospectus Download -->
		<section class="py-6 px-4 bg-white border-b border-gray-100">
			<div class="max-w-5xl mx-auto flex justify-end">
				<a
					href="/dcsots26-sponsor-prospectus.pdf"
					download
					class="inline-flex items-center gap-2 bg-teal text-white font-semibold px-5 py-2.5 rounded-lg hover:bg-teal/90 transition-colors text-sm"
				>
					<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V3" />
					</svg>
					Download Prospectus
				</a>
			</div>
		</section>

		<!-- Why Sponsor -->
		<section class="py-16 px-4 bg-pink/10">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-3xl font-bold text-navy text-center mb-4">Why Sponsor</h2>
				<p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">Sponsoring DC State of the Stack is an opportunity to engage with <strong class="text-navy">practitioners</strong> who care deeply about how systems actually work. The value of sponsorship here isn't just presence — <strong class="text-navy">it's credibility</strong>.</p>
				<div class="grid md:grid-cols-3 gap-6">
					{[
						{ title: 'Show up with practitioners', desc: 'Not just sales teams. Bring the people who actually build and operate software.' },
						{ title: 'Share real experiences', desc: 'Not product pitches. The community values honest conversation over polished decks.' },
						{ title: 'Engage in conversations', desc: 'Not transactions. Build relationships with engineers making real decisions.' },
					].map(({ title, desc }) => (
						<div class="bg-white rounded-xl p-6 border border-gray-100">
							<p class="font-bold text-pink mb-2">{title}</p>
							<p class="text-gray-600 text-sm">{desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Who Attends -->
		<section class="py-16 px-4 bg-white">
			<div class="max-w-5xl mx-auto">
				<div class="grid md:grid-cols-2 gap-12 items-start">
					<div>
						<h2 class="text-3xl font-bold text-navy mb-6">Who Attends</h2>
						<p class="text-gray-700 mb-4">DC State of the Stack draws practitioners from across the full DC tech ecosystem — <strong>over 200 attendees</strong> representing the organizations and institutions that define how technology is built and operated in this region.</p>
						<p class="text-gray-700 mb-6">Attendees are predominantly <strong>individual contributors, team leads, and first- and second-level managers</strong> — the people closest to the work. Skill sets span the full stack: development, operations, security, platform engineering, and everything in between.</p>
						<p class="text-gray-700 italic font-semibold">This isn't a homogeneous audience — it's the DC tech ecosystem in one room.</p>
					</div>
					<div class="space-y-4">
						{[
							{ label: 'Public Sector', desc: 'Federal agencies, civilian and defense, navigating complex delivery in high-stakes environments.' },
							{ label: 'Fortune 500 Enterprises', desc: 'Large organizations managing scale, compliance, and modernization in parallel.' },
							{ label: 'Startups', desc: 'Teams moving fast, building in the open, and solving problems the established players haven\'t caught up to yet.' },
							{ label: 'Nonprofits', desc: 'Mission-driven organizations doing serious technical work with real constraints.' },
						].map(({ label, desc }) => (
							<div class="border-l-4 border-teal pl-4">
								<p class="font-semibold text-navy">{label}</p>
								<p class="text-gray-600 text-sm">{desc}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Past Sponsors -->
		<section class="py-16 px-4 bg-pink/10">
			<div class="max-w-5xl mx-auto text-center">
				<h2 class="text-3xl font-bold text-navy mb-3">A Community Built Over Time</h2>
				<p class="text-gray-500 max-w-2xl mx-auto mb-3">Over the past decade — first as DevOpsDays DC, now as DC State of the Stack — this community has been supported by organizations that value real conversations, practitioner insight, and long-term relationships.</p>
				<p class="font-semibold text-navy">Same organizing team. Same community. Same spirit.</p>
			</div>
		</section>

		<!-- Sponsorship Tier Table -->
		<section class="py-16 px-4 bg-white">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-3xl font-bold text-navy text-center mb-2">Sponsorship Tiers and Benefits</h2>
				<p class="text-gray-500 text-center mb-10">Compare tiers by benefits, investment, and level of presence.</p>
				<div class="overflow-x-auto">
					<table class="w-full border-collapse text-sm">
						<thead>
							<tr>
								<th class="text-left p-3 w-1/3"></th>
								{['Platinum', 'Gold', 'Silver', 'Digital'].map((tier) => (
									<th class="p-3 text-center">
										<span class="bg-pink text-white font-bold rounded-lg px-4 py-2 inline-block">{tier}</span>
									</th>
								))}
							</tr>
						</thead>
						<tbody>
							{tierBenefits.map(({ label, platinum, gold, silver, digital, isPrice }, i) => (
								<tr class={i % 2 === 0 ? 'bg-purple-50/40' : 'bg-white'}>
									<td class={`p-3 ${isPrice ? 'font-bold text-navy' : 'text-gray-600'}`}>{label}</td>
									{[platinum, gold, silver, digital].map((val) => (
										<td class="p-3 text-center">
											{val === true ? (
												<span class="inline-flex items-center justify-center w-6 h-6 rounded-full border-2 border-navy text-navy font-bold text-xs">✓</span>
											) : val === false ? (
												<span class="text-gray-300">—</span>
											) : (
												<span class={isPrice ? 'font-bold text-navy text-base' : 'text-gray-700 text-xs'}>{val}</span>
											)}
										</td>
									))}
								</tr>
							))}
						</tbody>
					</table>
				</div>
				<p class="text-center mt-8">
					<a href="mailto:sponsors@dcstateofthestack.org" class="inline-block bg-teal text-white font-semibold px-8 py-3 rounded-lg hover:bg-teal/90 transition-colors">Become a Sponsor</a>
				</p>
			</div>
		</section>

		<!-- Additional Sponsorships -->
		<section class="py-16 px-4 bg-pink/10">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-3xl font-bold text-navy mb-2">Additional Sponsorships</h2>
				<p class="text-gray-600 mb-8">Can be purchased separately from Platinum, Gold, or Silver sponsorships — either in addition to those or as stand-alone investments.</p>
				<div class="grid md:grid-cols-2 gap-6">
					{[
						{ name: 'Hands-on Workshop', count: 2, price: '$2,000', desc: 'Platinum sponsors only: Dedicated room and 90-minute time slot for up to 30 participants during afternoon open spaces. We will assist with pre-event workshop registration.' },
						{ name: 'Social Hour', count: null, price: 'Negotiable', desc: 'The American Red Cross is an alcohol-free facility. If you\'d like to host an informal gathering after the event at a nearby venue, we\'ll help you find the right space and get the word out. Social Hour sponsors get signage, social media recognition, and the chance to bring the community together off-site.' },
						{ name: 'Lanyard Sponsor', count: 1, price: '$4,500', desc: 'Your logo on every attendee\'s lanyard for two days — worn by engineers, operators, and leaders from across the DC tech community. Single color logo. Final placement, size, and color subject to organizer approval.' },
						{ name: 'Closed Captioning Sponsor', count: 1, price: '$4,500', desc: 'We believe every attendee deserves to follow the conversation. Your logo appears on screen as talks are transcribed live — visible to everyone in the room, both days.' },
					].map(({ name, count, price, desc }) => (
						<div class="bg-pink/20 rounded-2xl p-6 border border-pink/30">
							<div class="flex justify-between items-start mb-3 pb-3 border-b border-pink/40">
								<h3 class="font-bold text-navy text-lg">{name}{count ? ` (${count})` : ''}</h3>
								<span class="text-pink font-bold text-lg">{price}</span>
							</div>
							<p class="text-gray-700 text-sm">{desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Food & Beverage -->
		<section class="py-16 px-4 bg-white">
			<div class="max-w-5xl mx-auto">
				<h2 class="text-3xl font-bold text-navy mb-2">Food and Beverage Sponsorships</h2>
				<p class="text-gray-600 mb-8">Can be purchased separately from Platinum, Gold, or Silver sponsorships — either in addition to those or as stand-alone investments.</p>
				<div class="grid md:grid-cols-2 gap-6">
					{[
						{ name: 'Breakfast', count: 1, price: '$2,000', desc: 'Signage with your logo at the breakfast tables both mornings. It\'s a low-key, high-visibility moment — practitioners fuel up, conversations start, and your brand is part of how the day begins.' },
						{ name: 'Lunch', count: 1, price: '$6,000', desc: 'Signage with your logo at the lunch tables both days. Lunch is one of the most natural networking moments at the conference — unhurried, conversational, and shared. Your brand is part of that.' },
						{ name: 'Break', count: 1, price: '$3,000', desc: 'Signage with your logo at the break tables during morning and afternoon breaks both days. Breaks are when the "hallway track" conversations happen — between sessions, away from the slides, over coffee.' },
					].map(({ name, count, price, desc }) => (
						<div class="bg-pink/20 rounded-2xl p-6 border border-pink/30">
							<div class="flex justify-between items-start mb-3 pb-3 border-b border-pink/40">
								<h3 class="font-bold text-navy text-lg">{name} ({count})</h3>
								<span class="text-pink font-bold text-lg">{price}</span>
							</div>
							<p class="text-gray-700 text-sm">{desc}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Community Sponsorships -->
		<section class="py-16 px-4 bg-navy text-white">
			<div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">
				<div>
					<h2 class="text-3xl font-bold mb-4">Community Sponsorships</h2>
					<p class="text-sm font-bold text-light-pink uppercase tracking-widest mb-3">Package Price: In Kind</p>
					<p class="text-gray-300 mb-4">We extend community sponsorships to regional conferences, media, and meetups that share our mission — building a stronger, more connected tech community across DC, Maryland, and Virginia.</p>
					<p class="font-semibold text-gray-200 mb-3">Community sponsors must be:</p>
					<ul class="space-y-2 text-gray-300 text-sm mb-4">
						<li class="flex gap-2"><span class="text-teal">•</span> Aligned with our mission to grow the DC tech community</li>
						<li class="flex gap-2"><span class="text-teal">•</span> Willing to help promote DC State of the Stack in kind</li>
						<li class="flex gap-2"><span class="text-teal">•</span> Willing to adhere to our code of conduct</li>
					</ul>
					<p class="text-gray-400 italic text-sm">This isn't a transactional relationship — it's a seat at the table for organizations that share our values.</p>
				</div>
				<div class="bg-white/10 rounded-2xl p-8 border border-white/20">
					<h3 class="font-bold text-light-pink uppercase tracking-widest text-sm mb-4">What's Included</h3>
					<ul class="space-y-3 text-gray-200">
						<li class="flex gap-2"><span class="text-teal">✓</span> 1 event ticket</li>
						<li class="flex gap-2"><span class="text-teal">✓</span> Main stage thank you</li>
						<li class="flex gap-2"><span class="text-teal">✓</span> Social media thank you</li>
						<li class="flex gap-2"><span class="text-teal">✓</span> Logo on the website</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-16 px-4 bg-pink/10">
			<div class="max-w-3xl mx-auto text-center bg-white rounded-2xl p-10 border border-pink/20 shadow-sm">
				<h2 class="text-3xl font-bold text-navy mb-4">Be Part of Something That Matters</h2>
				<p class="text-gray-600 mb-4">DC State of the Stack 2026 is where the DC tech community comes together to do the real work — no fluff, no theater, just honest conversation about how systems are actually built, operated, and governed.</p>
				<p class="text-gray-600 mb-8">Your sponsorship makes that possible. Join us September 16–17 at the American Red Cross National Headquarters.</p>
				<a href="mailto:sponsors@dcstateofthestack.org" class="inline-block bg-teal text-white font-semibold px-8 py-3 rounded-lg hover:bg-teal/90 transition-colors">sponsors@dcstateofthestack.org</a>
			</div>
		</section>

		<!-- Current Sponsors -->
		<section class="py-16 px-4 bg-white">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-12">
					<h2 class="text-3xl font-bold mb-4 text-navy">2026 Sponsors</h2>
					<div class="w-16 h-1 bg-teal mx-auto"></div>
				</div>

				<div class="space-y-12">
					{tiers.map(({ key, label }) => {
						const tierSponsors = allSponsors.filter(s => s.data.tier === key);

						return (
							<div>
								<div class="flex items-center gap-3 mb-6 pb-2 border-b border-slate-400">
									<h3 class="text-xl font-bold text-teal">{label}</h3>
								</div>
								{tierSponsors.length > 0 ? (
									<div class={`grid gap-6 ${key === 'platinum' ? 'grid-cols-2 md:grid-cols-3' : key === 'gold' ? 'grid-cols-2 md:grid-cols-4' : 'grid-cols-3 md:grid-cols-5'}`}>
										{tierSponsors.map((sponsor) => (
											<a
												href={sponsor.data.url || '#'}
												target="_blank"
												rel="noopener"
												class="bg-gray-50 border border-gray-100 rounded-xl p-6 flex items-center justify-center hover:border-teal hover:shadow-sm transition-all min-h-[100px]"
											>
												{sponsor.data.logo ? (
													<img src={sponsor.data.logo.src} alt={sponsor.data.name} class="max-h-12 max-w-full object-contain" />
												) : (
													<span class="text-navy font-semibold text-center">{sponsor.data.name}</span>
												)}
											</a>
										))}
									</div>
								) : (
									<p class="text-gray-400">No Sponsor Yet</p>
								)}
							</div>
						);
					})}
				</div>
			</div>
		</section>

	</div>

	<Footer />
</Layout>
